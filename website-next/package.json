{
  "name": "website-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "optimize-images": "node scripts/optimize-images.mjs",
    "generate-git-metadata": "node scripts/generate-git-metadata.mjs",
    "ci-local": "bash start-optimized.sh",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-storybook:test": "storybook build --quiet --output-dir storybook-static",
    "test:visual": "yarn build-storybook:test && playwright test",
    "test:visual:update": "yarn build-storybook:test && playwright test --update-snapshots"
  },
  "dependencies": {
    "@chillicream/mocha-visualizer": "file:../src/Mocha/src/mocha-visualizer",
    "@docsearch/css": "^4.6.3",
    "@docsearch/react": "^4.6.3",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@next/third-parties": "16.2.6",
    "@types/js-yaml": "^4.0.9",
    "@types/mdx": "^2.0.13",
    "@xyflow/react": "^12.10.0",
    "elkjs": "^0.11.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@storybook/nextjs-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-storybook": "10.4.1",
    "http-server": "^14.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rehype-mermaid": "^3.0.0",
    "storybook": "^10.4.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6"
  },
  "packageManager": "yarn@4.15.0",
  "browserslist": [
    "chrome >= 110",
    "firefox >= 110",
    "safari >= 16",
    "edge >= 110",
    "not dead",
    "not op_mini all"
  ],
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    },
    "sharp": {
      "built": true
    },
    "unrs-resolver": {
      "built": true
    }
  }
}
