-- @value='Brightex'
-- @value2='2'
-- @p4='3'
-- @p='2'
SELECT b."Id", b."GroupId", b."Name"
FROM "Brands" AS b
WHERE b."Name" > @value OR (b."Name" = @value AND b."Id" > @value2)
ORDER BY b."Name", b."Id"
LIMIT @p4 OFFSET @p
