-- @value='Quantumis'
-- @value2='17'
-- @p4='3'
-- @p='2'
SELECT b."Id", b."GroupId", b."Name"
FROM "Brands" AS b
WHERE b."Name" < @value OR (b."Name" = @value AND b."Id" < @value2)
ORDER BY b."Name" DESC, b."Id" DESC
LIMIT @p4 OFFSET @p
