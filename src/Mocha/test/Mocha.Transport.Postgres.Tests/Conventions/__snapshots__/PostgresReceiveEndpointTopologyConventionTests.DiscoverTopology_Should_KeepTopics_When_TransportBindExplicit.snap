{
  "Schema": "postgres",
  "TransportType": "PostgresMessagingTransport",
  "Entities": [
    {
      "Kind": "queue",
      "Name": "orders",
      "Origin": "declared"
    },
    {
      "Kind": "queue",
      "Name": "orders_error",
      "Origin": "endpoint"
    },
    {
      "Kind": "queue",
      "Name": "orders_skipped",
      "Origin": "endpoint"
    },
    {
      "Kind": "topic",
      "Name": "mocha.test-helpers.order-created",
      "Origin": "convention"
    },
    {
      "Kind": "topic",
      "Name": "order-created",
      "Origin": "convention"
    }
  ],
  "Links": [
    {
      "Kind": "subscription",
      "From": "postgres://localhost:5432/t/mocha.test-helpers.order-created",
      "To": "postgres://localhost:5432/q/orders",
      "Origin": "convention"
    },
    {
      "Kind": "subscription",
      "From": "postgres://localhost:5432/t/order-created",
      "To": "postgres://localhost:5432/q/orders",
      "Origin": "convention"
    }
  ]
}
