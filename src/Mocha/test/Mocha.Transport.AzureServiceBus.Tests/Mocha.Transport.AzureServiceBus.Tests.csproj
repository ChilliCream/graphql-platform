<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Test.props', '$(MSBuildThisFileDirectory)'))" />
  <PropertyGroup>
    <AssemblyName>Mocha.Transport.AzureServiceBus.Tests</AssemblyName>
    <RootNamespace>Mocha.Transport.AzureServiceBus.Tests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Squadron.AzureCloudServiceBus" />
    <!-- Squadron 1.0.1 still depends on the xUnit v2 runner assemblies. The repository uses
         xUnit v3, while Squadron only needs xunit.abstractions at runtime for its fixture sink. -->
    <PackageReference Include="xunit.extensibility.core" ExcludeAssets="compile" />
    <PackageReference Include="xunit.extensibility.execution" ExcludeAssets="compile" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Mocha.TestHelpers" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Mocha\Mocha.csproj" />
    <ProjectReference Include="..\..\src\Mocha.Inbox\Mocha.Inbox.csproj" />
    <ProjectReference Include="..\..\src\Mocha.Transport.AzureServiceBus\Mocha.Transport.AzureServiceBus.csproj" />
    <ProjectReference Include="..\Mocha.TestHelpers\Mocha.TestHelpers.csproj" />
  </ItemGroup>
</Project>
