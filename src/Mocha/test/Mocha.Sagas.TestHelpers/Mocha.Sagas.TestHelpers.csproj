<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>Mocha.Sagas.TestHelpers</AssemblyName>
    <RootNamespace>Mocha.Sagas.TestHelpers</RootNamespace>
    <!-- This is a shared test-helper library, not a runnable test project, so it builds as a
         Library instead of the Exe inherited from Directory.Build.props. -->
    <OutputType>Library</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Npgsql" />
    <PackageReference Include="Squadron.PostgreSql" />
    <PackageReference Include="xunit.v3.assert" />
    <!-- Drop the xunit.v3 runner (also inherited): a library has no test entry point, and the
         runner's build targets require an Exe output type. -->
    <PackageReference Remove="xunit.v3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Mocha\Mocha.csproj" />
    <ProjectReference Include="..\..\src\Mocha.Outbox\Mocha.Outbox.csproj" />
    <ProjectReference Include="..\..\src\Mocha.Transport.InMemory\Mocha.Transport.InMemory.csproj" />
  </ItemGroup>
</Project>
