{
  "Schema": "rabbitmq",
  "TransportType": "RabbitMQMessagingTransport",
  "Entities": [
    {
      "Kind": "exchange",
      "Name": "source-fanout-exchange",
      "AutoProvision": true,
      "Origin": "declared"
    },
    {
      "Kind": "queue",
      "Name": "orders",
      "AutoProvision": true,
      "Origin": "declared"
    },
    {
      "Kind": "queue",
      "Name": "orders_error",
      "AutoProvision": true,
      "Origin": "convention"
    },
    {
      "Kind": "queue",
      "Name": "orders_skipped",
      "AutoProvision": true,
      "Origin": "convention"
    }
  ],
  "Links": [
    {
      "Kind": "bind",
      "From": "rabbitmq://localhost:5672/e/source-fanout-exchange",
      "To": "rabbitmq://localhost:5672/q/orders",
      "AutoProvision": true,
      "Origin": "declared"
    }
  ]
}
