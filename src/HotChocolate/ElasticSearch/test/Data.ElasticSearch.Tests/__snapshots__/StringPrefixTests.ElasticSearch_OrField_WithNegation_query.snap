{
  "query": {
    "bool": {
      "filter": [
        {
          "bool": {
            "should": [
              {
                "query_string": {
                  "query": "bar.keyword:th*"
                }
              },
              {
                "bool": {
                  "must_not": [
                    {
                      "query_string": {
                        "query": "bar.keyword:I*"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  }
}
