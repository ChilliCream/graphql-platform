schema {
  query: Query
}

type Query {
  intId(id: ID!): String!
  stringId(id: ID!): String!
  guidId(id: ID!): String!
  foo(input: FooInput): IFooPayload
}

type FooPayload implements IFooPayload {
  someId: ID!
  anotherId: ID!
}

interface IFooPayload {
  someId: ID!
  anotherId: ID!
}

input FooInput {
  someId: ID!
  anotherId: ID!
}
