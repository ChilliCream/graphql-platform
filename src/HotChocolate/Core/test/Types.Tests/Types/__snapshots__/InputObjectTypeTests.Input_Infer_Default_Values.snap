schema {
  query: Query
}

type Query {
  abc(def: InputWithDefaultInput): String
}

input ComplexInput {
  foo: Int!
}

input InputWithDefaultInput {
  withStringDefault: String = "abc"
  withNullDefault: String = null
  enum: FooEnum! = BAR
  complexInput: [[ComplexInput!]!]! = [[{ foo: 1 }]]
  withoutDefault: String
}

enum FooEnum {
  BAR
  BAZ
}
