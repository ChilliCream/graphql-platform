schema {
  query: QueryA
}

type QueryA {
  bar(id: FOO): Bar
}

type Bar {
  baz: Baz
}

type Baz {
  text: Decimal!
}

"The `Decimal` scalar type represents a decimal floating-point number with high precision."
scalar Decimal
  @specifiedBy(url: "https://scalars.graphql.org/chillicream/decimal.html")

scalar FOO
