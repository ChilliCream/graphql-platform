schema {
  query: QueryDateTime1
}

type QueryDateTime1 {
  foo: Foo!
}

type Foo {
  localDateTime(localDateTime: LocalDateTime): LocalDateTime
}

"The `LocalDateTime` scalar type represents a date and time without time zone information."
scalar LocalDateTime
  @specifiedBy(url: "https://scalars.graphql.org/chillicream/local-date-time.html")
