schema {
  query: QueryDateTime1
}

type QueryDateTime1 {
  foo: Foo!
}

type Foo {
  date(date: LocalDate!): LocalDate!
}

"The `LocalDate` scalar type represents a date without time or time zone information."
scalar LocalDate
  @specifiedBy(url: "https://scalars.graphql.org/chillicream/local-date.html")
