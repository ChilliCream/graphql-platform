schema {
  query: QueryWithDateTime
}

type QueryWithDateTime {
  model: ModelWithDateTime
}

type ModelWithDateTime {
  foo: Date
  bar: DateTime!
}

"The `Date` scalar type represents a date in UTC."
scalar Date
  @specifiedBy(url: "https://scalars.graphql.org/chillicream/date.html")

"The `DateTime` scalar type represents a date and time with time zone offset information."
scalar DateTime
  @specifiedBy(url: "https://scalars.graphql.org/chillicream/date-time.html")
