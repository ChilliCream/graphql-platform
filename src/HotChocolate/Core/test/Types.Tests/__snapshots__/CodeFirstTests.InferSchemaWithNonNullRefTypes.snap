schema {
  query: Query
}

type Query {
  sayHello(name: String!): String!
  greetings(greetings: GreetingsInput!): Greetings!
  pet: IPet!
  petOrNull: IPet
}

type Dog implements IPet {
  name: String
}

type Greetings {
  name: String!
}

interface IPet {
  name: String
}

input GreetingsInput {
  name: String!
}
