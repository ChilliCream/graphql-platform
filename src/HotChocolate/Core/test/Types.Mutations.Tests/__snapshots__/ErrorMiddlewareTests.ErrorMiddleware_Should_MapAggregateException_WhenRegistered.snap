schema:
---------------
schema {
  mutation: Mutation
}

type Mutation {
  throw: ThrowPayload!
}

type ArgumentError implements Error {
  message: String!
  paramName: String
}

type CustomError implements Error {
  message: String!
}

type CustomNullRef implements Error {
  message: String!
}

type Payload {
  foo: String!
}

type ThrowPayload {
  payload: Payload
  errors: [ThrowError!]
}

interface Error {
  message: String!
}

union ThrowError = CustomError | CustomNullRef | ArgumentError
