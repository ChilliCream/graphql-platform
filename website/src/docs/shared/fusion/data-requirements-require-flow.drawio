<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Client -->
    <mxCell id="client" value="Client" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;verticalAlign=middle;spacingTop=0;" vertex="1" parent="1">
      <mxGeometry x="40" y="180" width="120" height="50" as="geometry"/>
    </mxCell>

    <!-- Gateway -->
    <mxCell id="gw" value="Gateway" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="280" y="180" width="120" height="50" as="geometry"/>
    </mxCell>

    <!-- Products Subgraph -->
    <mxCell id="products" value="Products&#xa;Subgraph" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=13;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="540" y="80" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- Shipping Subgraph -->
    <mxCell id="shipping" value="Shipping&#xa;Subgraph" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=13;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="540" y="280" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- Step 1: Client to Gateway -->
    <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=11;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="client" target="gw">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e1label" value="productById(1) {&#xa;  name&#xa;  deliveryEstimate(zip: &quot;10001&quot;)&#xa;}" style="text;align=left;fontSize=10;fontFamily=monospace;fontColor=#333333;verticalAlign=bottom;" vertex="1" parent="1">
      <mxGeometry x="120" y="115" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Step 2: Gateway to Products -->
    <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=1.5;fontSize=11;exitX=1;exitY=0.25;entryX=0;entryY=0.5;" edge="1" parent="1" source="gw" target="products">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="460" y="193"/>
          <mxPoint x="460" y="105"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e2label" value="&#10102; Fetch name, weight, dimensions" style="text;align=left;fontSize=11;fontColor=#82b366;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="415" y="60" width="230" height="20" as="geometry"/>
    </mxCell>

    <!-- Step 3: Products returns data to Gateway -->
    <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=1.5;dashed=1;fontSize=11;exitX=0;exitY=0.5;entryX=0.75;entryY=0;dashPattern=6 3;" edge="1" parent="1" source="products" target="gw">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="490" y="105"/>
          <mxPoint x="490" y="160"/>
          <mxPoint x="370" y="160"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e3label" value="{ name, weight: 500,&#xa;  dimensions: { length, width, height } }" style="text;align=left;fontSize=10;fontFamily=monospace;fontColor=#999999;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="285" y="135" width="270" height="30" as="geometry"/>
    </mxCell>

    <!-- Step 4: Gateway to Shipping with resolved @require data -->
    <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=1.5;fontSize=11;exitX=1;exitY=0.75;entryX=0;entryY=0.5;" edge="1" parent="1" source="gw" target="shipping">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="460" y="218"/>
          <mxPoint x="460" y="305"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e4label" value="&#10103; Pass zip + resolved @require data" style="text;align=left;fontSize=11;fontColor=#82b366;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="415" y="250" width="250" height="20" as="geometry"/>
    </mxCell>

    <!-- Annotation: what @require resolved -->
    <mxCell id="requireNote" value="@require resolved:&#xa;weight: 500&#xa;dimensions: { length, width, height }" style="text;align=left;fontSize=10;fontFamily=monospace;fontColor=#b85450;fontStyle=2;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="460" y="325" width="260" height="45" as="geometry"/>
    </mxCell>

    <!-- Step 5: Shipping returns to Gateway -->
    <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=1.5;dashed=1;fontSize=11;exitX=0;exitY=0.5;entryX=0.75;entryY=1;dashPattern=6 3;" edge="1" parent="1" source="shipping" target="gw">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="490" y="305"/>
          <mxPoint x="490" y="250"/>
          <mxPoint x="370" y="250"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e5label" value="{ deliveryEstimate: 4 }" style="text;align=left;fontSize=10;fontFamily=monospace;fontColor=#999999;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="310" y="252" width="170" height="20" as="geometry"/>
    </mxCell>

    <!-- Step 6: Gateway to Client (merged response) -->
    <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=1.5;dashed=1;fontSize=11;exitX=0;exitY=0.5;entryX=1;entryY=0.5;dashPattern=6 3;" edge="1" parent="1" source="gw" target="client">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="220" y="205"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e6label" value="{ name: &quot;Widget&quot;,&#xa;  deliveryEstimate: 4 }" style="text;align=left;fontSize=10;fontFamily=monospace;fontColor=#333333;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="115" y="225" width="180" height="30" as="geometry"/>
    </mxCell>

    <!-- Title -->
    <mxCell id="title" value="Gateway resolves @require dependencies before calling the downstream subgraph" style="text;align=center;fontSize=12;fontStyle=1;fontColor=#666666;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="80" y="380" width="600" height="20" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
